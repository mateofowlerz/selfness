# Lister configuration. Copy to .env and fill in. Only eBay needs developer
# credentials; Depop and Vinted work through interactive sign-in by default.

# --- eBay (official OAuth, required to enable the eBay connection) ---
# Create an app at https://developer.ebay.com/ to get these.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# The registered redirect URI / RuName for the OAuth flow.
EBAY_REDIRECT_URI=
# Set to "true" to target the eBay sandbox while developing.
EBAY_SANDBOX=true
# Marketplace + default selling policies (find IDs via the Account API).
EBAY_MARKETPLACE_ID=EBAY_GB
EBAY_DEFAULT_CATEGORY_ID=
EBAY_FULFILLMENT_POLICY_ID=
EBAY_PAYMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=

# --- Depop ---
# Optional. If you have been granted Depop Selling API partner access, set the
# API key here to publish via the official API instead of the browser session.
DEPOP_API_KEY=
DEPOP_BASE_URL=https://www.depop.com

# --- Vinted ---
# Override for non-UK marketplaces, e.g. https://www.vinted.fr
VINTED_BASE_URL=https://www.vinted.co.uk
